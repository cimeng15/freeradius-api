            }
          }
        },
        {
          "name": "Delete Client",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/clients/1",
              "host": ["{{base_url}}"],
              "path": ["clients", "1"]
            }
          }
        }
      ]
    }
  ]
}
