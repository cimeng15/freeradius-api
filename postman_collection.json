            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"username\": \"john123\",\n  \"password\": \"password123\",\n  \"package_id\": 1,\n  \"ip_address\": null,\n  \"installation_address\": \"Jl. Example No. 123, Jakarta\",\n  \"phone\": \"081234567890\",\n  \"billing_date\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/clients",
              "host": ["{{base_url}}"],
              "path": ["clients"]
            }
          }
        },
        {
          "name": "Show Client",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/clients/1",
              "host": ["{{base_url}}"],
              "path": ["clients", "1"]
            }
          }
        },
        {
          "name": "Update Client",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
